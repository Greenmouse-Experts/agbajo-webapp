# REST API base URL
VITE_API_URL=https://agbajo-backend.onrender.com/

# Paystack inline popup public key (pk_test_... or pk_live_...)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# WebSocket / Socket.IO URL (used by chatSocket, userChatSocket)
VITE_BACKEND_URL=wss://agbajo-backend.onrender.com

# Public frontend URL — used to build Stripe Checkout redirect URLs.
# Must match what the backend's FRONTEND_URL env var is set to.
VITE_APP_URL=http://localhost:3000
